<header class="z-1000 sticky top-0 bg-white" data-sidePanel-target="header">
    <div class="flex flex-col">
        <div class="p-3 flex flex-row items-center justify-between gap-4">

            {# Hamburger — flex sur mobile, caché sur md+ #}
            <button
                id="hamburger-btn"
                class="flex lg:hidden cursor-pointer bg-transparent border-none p-1"
                aria-label="Ouvrir le menu"
                aria-expanded="false"
                aria-controls="mobile-nav">
                <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24"
                    class="w-8 h-8 md:w-15 md:h-15">
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <line x1="3" y1="12" x2="21" y2="12"/>
                    <line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
                <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24"
                    class="w-8 h-8 md:w-15 md:h-15" style="display:none;">
                    <line x1="4" y1="4" x2="20" y2="20"/>
                    <line x1="20" y1="4" x2="4" y2="20"/>
                </svg>
            </button>

            {# Logo #}
            <div class="flex-shrink-0">
                <img class="w-12 md:hidden" src="{{ asset("/image/maison_kalyste_m.png") }}" alt="Logo de Maison Kalyste">
            </div>

            {# Titre #}
            <div class="flex-1 text-center">
                <h1 class="font-allura text-3xl md:text-4xl leading-tight">
                    <a href="{{ path("app_home") }}">
                        <span class="pe-2 md:pe-5">Maison</span>Kalyste
                    </a>
                </h1>
            </div>

            {# Actions #}
            <div class="flex-shrink-0 flex flex-row items-center gap-2">
                <a href="
                    {% if not is_granted('IS_AUTHENTICATED_FULLY') %}
                        {{ path("app_login") }}
                    {% else %}
                        {{ path("app_account_my") }}
                    {% endif %}
                " class="cursor-pointer">
                    <img class="w-8 md:w-10" src="{{ asset("/image/ui/account.svg") }}" alt="Mon compte">
                </a>

                <a data-cart-target="button" class="cursor-pointer relative">
                    <img class="w-8 md:w-10" src="{{ asset("/image/ui/cart.svg") }}" alt="Panier">
                    <span data-cart-target="count"
                          class="hidden absolute -top-1 -right-1 bg-(--primary-color) text-white text-xs font-bold w-5 h-5 rounded-full flex items-center justify-center">
                    </span>
                </a>
            </div>
        </div>

        {# Nav desktop — masquée sur mobile #}
        <nav class="hidden md:block overflow-x-auto scrollbar-none py-1 bg-(--third-color)" aria-label="Barre de navigation">
            <ul class="flex justify-center gap-6">
                <li><a href="" class="btn-header">Collections</a></li>
                <li><a href="" class="btn-header">Nouveautés</a></li>
                <li><a href="" class="btn-header">Best-sellers</a></li>
                <li><a href="" class="btn-header">Vêtements</a></li>
                <li><a href="" class="btn-header">Accessoires</a></li>
                <li><a href="" class="btn-header">Promotions</a></li>
            </ul>
        </nav>

        {# Nav mobile — dépliable #}
        <nav
            id="mobile-nav"
            class="md:hidden overflow-hidden max-h-0 transition-[max-height] duration-300 ease-in-out bg-white border-t border-gray-100"
            aria-label="Menu mobile"
        >
            <ul class="flex flex-col py-2">
                <li><a href="" class="btn-header block px-5 py-3 border-b border-gray-100">Collections</a></li>
                <li><a href="" class="btn-header block px-5 py-3 border-b border-gray-100">Nouveautés</a></li>
                <li><a href="" class="btn-header block px-5 py-3 border-b border-gray-100">Best-sellers</a></li>
                <li><a href="" class="btn-header block px-5 py-3 border-b border-gray-100">Vêtements</a></li>
                <li><a href="" class="btn-header block px-5 py-3 border-b border-gray-100">Accessoires</a></li>
                <li><a href="" class="btn-header block px-5 py-3">Promotions</a></li>
            </ul>
        </nav>
    </div>
</header>