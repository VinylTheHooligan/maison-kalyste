{% extends "base.html.twig" %}

{% block title %}{{ parent() }} - Activation{% endblock %}

{% block body %}
        <div class="flex flex-col items-center bg-(--third-color) my-15 py-15">
            <h2 class="text-2xl font-bold">Renvoyer l'e-mail d'activation</h2>
            <span class="text-sm text-wrap w-80 text-center">Vous n'avez pas reçu le mail d'activation ou le lien est expiré ?</span>

            {{ form_start(form) }}
                <div class="flex flex-col w-100 my-10">
                    {{ form_label(form.email, null, {
                            label_attr: { class: 'form-label' }
                    }) }}
                    {{ form_widget(form.email, {
                            attr: { class: 'form-input' }
                    }) }}
                </div>

                <button class="form-button">Envoyer</button>
            {{ form_end(form) }}
        </div>
{% endblock %}