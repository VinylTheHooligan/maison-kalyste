{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} - Connexion{% endblock %}

{% block body %}
    <div class="bg-(--third-color) my-10 py-15">
        <div class="grid grid-cols-2 grid-rows-1 gap-4">
            <form method="post">
                <div class="flex flex-col items-center">
                    <h2 class="font-bold text-3xl">Connexion</h2>
                    {% if app.user %}
                    <div class="flex flex-col gap-6 my-3 text-sm text-center">
                        <p>Vous êtes déjà connecté en tant que <b>{{ app.user.userIdentifier }}</b>.</p>
                        <a class="form-button text-lg" href="{{ logout_path() }}">Se déconnecté ?</a>
                    </div>
                    {% else %}
                        <div class="text-sm text-center font-semibold">
                            <span>Vous avez déjà un compte :</span>
                            <div class="flex flex-col items-center my-5 w-fit gap-2">
                                <div class="flex flex-col">
                                    <label class="form-label" for="username">Votre e-mail</label>
                                    <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-input w-80" autocomplete="email" required autofocus>
                                </div>
                                <div class="flex flex-col">
                                    <label class="form-label" for="password">Votre mot de passe</label>
                                    <input type="password" name="_password" id="password" class="form-input w-80" autocomplete="current-password" required>
                                </div>
                            </div>
                            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">
                            <div class="form-checklabel mb-3">
                                <input type="checkbox" name="_remember_me" id="_remember_me">
                                <label class="ml-1 font-bold" for="_remember_me">Se souvenir de moi</label>
                            </div>
                        </div>
                        <div class="w-100">
                            <button class="form-button" type="submit">Connexion</button>
                        </div>
                    {% endif %}
                </div>
            </form>
            <div class="flex flex-col items-center">
                <h2 class="font-bold text-3xl">Inscription</h2>
                <span class="text-sm font-semibold">Vous n'avez pas de compte :</span>
                <div class="my-12">
                    <a href="{{ path("app_register") }}" class="form-button px-30">Créer un compte</a>
                </div>
                <a class="text-sm font-semibold" href="{{ path("app_resend_activation") }}">Lien d'activation non-reçu / expiré ?</a>
            </div>
        </div>
    </div>
{% endblock %}
