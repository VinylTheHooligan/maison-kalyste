{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block body %}
    <div class="grid grid-cols-2 grid-rows-1 gap-4 my-20">
        <form method="post">
            {% if error %}
                <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            {% if app.user %}
                <div class="mb-3">
                    You are logged in as {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">Logout</a>
                </div>
            {% endif %}

            <div class="flex flex-col items-center">
                <h2 class="font-bold text-2xl">Connexion</h2>

                <div class="text-sm text-center">
                    <span>Vous avez déjà un compte :</span>
                    <div class="flex flex-col items-center my-5 w-fit">
                        <label for="username">Votre e-mail</label>
                        <input type="email" value="{{ last_username }}" name="_username" id="username" class="w-80" autocomplete="email" required autofocus>
                        <label for="password">Votre mot de passe</label>
                        <input type="password" name="_password" id="password" class="w-80" autocomplete="current-password" required>
                    </div>
                    <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">
                    <div class="checkbox mb-3">
                        <input type="checkbox" name="_remember_me" id="_remember_me">
                        <label for="_remember_me">Se souvenir de moi</label>
                    </div>
                </div>

                <div class="w-100">
                    <button class="form-button" type="submit">Connexion</button>
                </div>
            </div>
        </form>
        <div class="flex flex-col items-center">
            <h2 class="font-bold text-2xl">Inscription</h2>
            <span class="text-sm">Vous n'avez pas de compte :</span>
            <div class="w-100 mt-5">
                <a href="{{ path("app_signin") }}" class="form-button">Créer un compte</a>
            </div>
        </div>
    </div>
{% endblock %}
