{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} - Créer votre compte{% endblock %}

{% block body %}
    <div class="flex flex-col items-center bg-(--third-color) my-10 py-10">
        <div class="text-center mb-3">
            <h2 class="font-bold text-2xl">Nouveau client ?</h2>
            <span>Bienvenu !</span>
        </div>

        <div class="w-150">
            {{ form_start(form) }}
                <div class="flex flex-col gap-6">
                    <div class="grid grid-cols-2 gap-3">
                        <div class="flex flex-col">
                            {{ form_label(form.firstName, null, {
                                label_attr: { class: 'form-label' }
                            }) }}
                            {{ form_widget(form.firstName, {
                                attr: { class: 'form-input' }
                            }) }}
                            {{ form_errors(form.firstName) }}
                        </div>
                        <div class="flex flex-col">
                            {{ form_label(form.lastName, null, {
                                label_attr: { class: 'form-label' }
                            }) }}
                            {{ form_widget(form.lastName, {
                                attr: { class: 'form-input' }
                            }) }}
                            {{ form_errors(form.lastName) }}
                        </div>
                    </div>
                    <div class="flex flex-col">
                        {{ form_label(form.username, null, {
                            label_attr: { class: 'form-label' }
                        }) }}
                        {{ form_widget(form.username, {
                            attr: { class: 'form-input' }
                        }) }}
                        {{ form_errors(form.username) }}
                    </div>
                    <div class="flex flex-col">
                        {{ form_label(form.email, null, {
                            label_attr: { class: 'form-label' }
                        }) }}
                        {{ form_widget(form.email, {
                            attr: { class: 'form-input' }
                        }) }}
                        {{ form_errors(form.email) }}
                    </div>
                    <div class="flex flex-col">
                        {{ form_label(form.plainPassword.first, null, {
                            label_attr: { class: 'form-label' }
                        }) }}
                        {{ form_widget(form.plainPassword.first, {
                            attr: { class: 'form-input' }
                        }) }}
                        {{ form_errors(form.plainPassword.first) }}
                    </div>
                    <div class="flex flex-col">
                        {{ form_label(form.plainPassword.second, null, {
                            label_attr: { class: 'form-label' }
                        }) }}
                        {{ form_widget(form.plainPassword.second, {
                            attr: { class: 'form-input' }
                        }) }}
                        {{ form_errors(form.plainPassword.second) }}
                    </div>
                    <div>
                        {{ form_widget(form.agreeTerms) }}
                        {{ form_label(form.agreeTerms, null, {
                            label_attr: { class: 'form-checklabel' }
                        }) }}
                        {{ form_errors(form.agreeTerms) }}
                    </div>
                    <div>
                        {{ form_row(form.submit) }}
                    </div>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}