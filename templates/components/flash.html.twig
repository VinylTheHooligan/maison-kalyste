{% set config = {
    success: {
        icon: 'text-green-600',
        bg: 'bg-green-50 border border-green-200',
        title: 'Succès'
    },
    error: {
        icon: 'text-red-600',
        bg: 'bg-red-50 border border-red-200',
        title: 'Erreur'
    },
    warning: {
        icon: 'text-yellow-600',
        bg: 'bg-yellow-50 border border-yellow-200',
        title: 'Attention'
    },
    info: {
        icon: 'text-blue-600',
        bg: 'bg-blue-50 border border-blue-200',
        title: 'Information'
    }
} %}

{% set style = config[type] ?? config.info %}
{% set id = 'toast-' ~ type ~ '-' ~ random() %}

<div id="{{ id }}"
     data-controller="toast"
     class="transition-all duration-200 w-full max-w-xs p-4 text-sm rounded-base shadow-xs border {{ style.bg }}">
  
  <div class="flex items-center justify-between">
    <div class="flex items-center">
      <svg class="w-4 h-4 shrink-0 me-2 {{ style.icon }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M10 11h2v5m-2 0h4m-2.592-8.5h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
      </svg>
      <h3 class="font-semibold">{{ style.title }}</h3>
    </div>

    <button type="button"
            data-action="toast#dismiss"
            aria-label="Close"
            class="cursor-pointer ms-auto -mx-1.5 -my-1.5 rounded p-1.5 hover:bg-gray-200 inline-flex items-center justify-center h-8 w-8">
      <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M6 18 17.94 6M18 18 6.06 6"/>
      </svg>
    </button>
  </div>

  <div class="mt-2">
    {{ message }}
  </div>
</div>
